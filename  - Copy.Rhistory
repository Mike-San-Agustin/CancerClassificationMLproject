library(vroom)
library(ggplot2)
library(readr)
library(corrplot)
library(skimr)
library(purrr)
library(GGally)
library(missForest)
library(tidymodels)
library(dials)
tidymodels_prefer()
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
t1.cex = 0.5,
type = "upper"
)
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
t1.cex = 0.5,
type = "upper",
mar = c(0, 0, 1, 0)
)
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
t1.cex = 0.5,
type = "upper",
mar = c(0, 0, 1, 0),
addCoeff.col = NULL
)
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
t1.cex = 0.5,
tl.srt = 60
type = "upper",
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
t1.cex = 0.5,
tl.srt = 60,
type = "upper",
mar = c(0, 0, 1, 0),
addCoeff.col = NULL
)
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
t1.cex = 0.5,
tl.srt = 60,
order = "hclust",
type = "upper",
mar = c(0, 0, 1, 0),
addCoeff.col = NULL
)
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
t1.cex = 0.1,
tl.srt = 60,
order = "hclust",
type = "upper",
mar = c(0, 0, 1, 0),
addCoeff.col = NULL
)
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
t1.cex = 0.1,
tl.srt = 90,
order = "hclust",
type = "upper",
mar = c(0, 0, 1, 0),
addCoeff.col = NULL
)
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
method = "color",
t1.cex = 0.1,
tl.srt = 90,
order = "hclust",
type = "upper",
mar = c(0, 0, 1, 0),
addCoeff.col = NULL
)
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
method = "color",
t1.cex = 0.1,
tl.srt = 45,
order = "hclust",
type = "upper",
mar = c(0, 0, 1, 0),
addCoeff.col = NULL
)
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
method = "color",
t1.cex = 0.1,
tl.srt = 45,
tl.col = "black",
order = "hclust",
type = "upper",
mar = c(0, 0, 1, 0),
addCoeff.col = NULL
)
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
method = "color",
t1.cex = 0.1,
tl.srt = 45,
tl.col = "black",
order = "hclust",
type = "upper",
mar = c(0, 0, 1, 0),
addCoef.col = "black",
number.cex = 0.7
)
#Correlation heatmap
corrplot(
cell_deformity |> select(-ID, -Diagnosis) |> cor(),
method = "color",
t1.cex = 0.1,
tl.srt = 45,
tl.col = "black",
order = "hclust",
type = "upper",
mar = c(0, 0, 1, 0),
addCoef.col = NULL
)
