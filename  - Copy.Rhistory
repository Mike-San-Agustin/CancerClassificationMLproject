library(vroom)
library(ggplot2)
library(readr)
library(corrplot)
library(skimr)
library(purrr)
library(GGally)
library(missForest)
library(tidymodels)
library(dials)
tidymodels_prefer()
plot <-
cell_deformity |>
pivot_longer(cols = 3:32, names_to =  "varname", values_to = "value")|>
ggplot(aes(x = Diagnosis, y = value, fill = Diagnosis)) +
#ggbeeswarm::geom_beeswarm(size = 2.5) +
geom_boxplot()+
theme_minimal() +
facet_wrap(~ varname, scales = "free_y")
plot
plot <-
cell_deformity |>
pivot_longer(cols = 3:32, names_to =  "varname", values_to = "value")|>
ggplot(aes(x = Diagnosis, y = value, fill = Diagnosis)) +
#ggbeeswarm::geom_beeswarm(size = 2.5) +
geom_boxplot()+
theme_minimal() +
facet_wrap(~ varname, scales = "free_y")
plot
plot <-
cell_deformity |>
pivot_longer(cols = 3:32, names_to =  "varname", values_to = "value")|>
ggplot(aes(x = Diagnosis, y = value, fill = Diagnosis)) +
ggbeeswarm::geom_beeswarm(size = 2.5) +
geom_boxplot()+
theme_minimal() +
facet_wrap(~ varname, scales = "free_y")
plot
#cov(cell_deformity |> select(-ID, -Diagnosis))
sdev <- prcomp(cell_deformity|> select(-ID, -Diagnosis)) |> pluck("sdev")
tot_var <- sdev^2/sum(sdev^2)
scores <-
prcomp(cell_deformity|> select(-ID, -Diagnosis)) |>
pluck("x") |>
as.data.frame() |>
select(PC1, PC2, PC3) |>
cbind(cell_deformity|> select(ID, Diagnosis))
scores |>
plotly::plot_ly(
x = ~PC1,
y = ~PC2,
z = ~PC3,
type = "scatter3d",
mode = "markers",
text = ~ID,
color = ~Diagnosis,
colorscale = "Viridis"
)
